# built sidecar binaries (produced by scripts/build-sidecar.sh)
/bin/
# release artifacts (produced by scripts/build-update-package.sh, attached to Releases)
/dist/
# caches / OS junk
__pycache__/
*.pyc
.DS_Store

# PixInsight signing keys — MUST NEVER enter this public repo
*.xssk

# stray local Go build output
/sidecar/wbpp-sidecar
/sidecar/wbpp-sidecar.exe

# local screenshots / scratch images — never part of the repo (trace risk)
/*.png
/*.jpg
/*.jpeg

# local/dev test harness (not published; sanitize before ever adding)
/pjsr/test/
